<mxfile host="app.diagrams.net" modified="2026-07-16T02:14:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="controlled-provider-v2" name="Controlled Provider V2">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="application" value="Application Coordinator&#xa;existing SingleCallToolActionPortV1 only&#xa;never holds V2 Governance or FactPort" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12" vertex="1" parent="1"><mxGeometry x="30" y="80" width="250" height="120" as="geometry"/></mxCell>
        <mxCell id="tool" value="Tool Application Adapter&#xa;holds Governance PortV2&#xa;submits exact Route/Boundary/Prepared request&#xa;no Entry FactPort / raw Provider" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="1"><mxGeometry x="340" y="70" width="260" height="140" as="geometry"/></mxCell>
        <mxCell id="route" value="Runtime ports owns exactly 6 nominal types&#xa;DeclarationRef / ConformanceRef / CurrentRef / Projection / Reader / existing MatrixKeyV3&#xa;all Go fields use core.Revision/core.Digest + snake_case JSON tags&#xa;Generation=GenerationArtifactRefV1&#xa;Handoff and ActiveRoute=flattened exact ID/revision/digest&#xa;7 bindings=ProviderBindingRefV2 with field-role Capability checks&#xa;DeclRef={RouteID,Revision,PublisherComponentID,DeclarationDigest}&#xa;ConfRef={ConformanceID,Revision,DeclarationRef,ConformanceDigest}&#xa;ConformanceID=Derive(RouteID,GenerationRef,BindingSetID)&#xa;Harness: Declaration/Conformance/RouteCurrent Fact Owner&#xa;CurrentID=Derive(RouteID,MatrixDigest); Revision CAS&#xa;Watermark=Generation/Handoff/BindingSet/ActiveRoute/7 bindings/WiringInventory&#xa;InspectCurrentControlledOperationProviderRouteV2(&#xa;context.Context,&#xa;ControlledOperationProviderRouteCurrentRefV2,&#xa;OperationScopeEvidenceApplicabilityMatrixKeyV3)&#xa;(ControlledOperationProviderRouteCurrentProjectionV2, error)&#xa;same-ID drift=Conflict; absent ID=NotFound&#xa;Invalid/NotFound/Conflict/Expired/Unavailable/Unknown map core.DomainError" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=7" vertex="1" parent="1"><mxGeometry x="560" y="0" width="480" height="390" as="geometry"/></mxCell>
        <mxCell id="gateway" value="Runtime Governance Gateway&#xa;composition-injected exact CurrentRef; no discovery&#xa;fresh reread all route Bindings&#xa;ProviderTransport + provider role separate&#xa;scan both aliases/raw injection&#xa;derive stable Entry ID&#xa;Prepared full projection&#xa;Evidence + Applicability Policies separate&#xa;Unified NotAfter without fake Application TTL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1"><mxGeometry x="1010" y="25" width="300" height="240" as="geometry"/></mxCell>
        <mxCell id="owner" value="Runtime Entry Owner single lock&#xa;CreateEnteredResultV2&#xa;created =&gt; opaqueClaim&#xa;existing =&gt; no claim&#xa;64 concurrent =&gt; one claim" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12" vertex="1" parent="1"><mxGeometry x="1360" y="55" width="270" height="170" as="geometry"/></mxCell>
        <mxCell id="runner" value="Kernel-internal RunnerV2&#xa;same-call-stack Authorization only&#xa;raw Provider only held here&#xa;Authorization never Fact/Result/log/sidecar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12" vertex="1" parent="1"><mxGeometry x="1360" y="320" width="270" height="160" as="geometry"/></mxCell>
        <mxCell id="provider" value="Declaration has ProviderTransport + closed provider role&#xa;post-bind Transport channel and actual Provider authority separately&#xa;scan aliases and real injection for both&#xa;raw Provider irreversible admission via Runner only&#xa;same stable idempotency key&#xa;atomic fresh NotAfter check + admission&#xa;receipt or unknown; raw return is not Observation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11" vertex="1" parent="1"><mxGeometry x="1000" y="315" width="310" height="210" as="geometry"/></mxCell>
        <mxCell id="inspect" value="ControlledProviderInspectPortV2&#xa;read-only original Prepared/Attempt from Entry&#xa;caller cannot replace coordinates&#xa;exact State Plane Observation or unknown" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12" vertex="1" parent="1"><mxGeometry x="650" y="320" width="300" height="160" as="geometry"/></mxCell>
        <mxCell id="result" value="Public ResultV2&#xa;entered | unknown | observed | rejected_no_effect&#xa;no-effect requires verifiable receipt and no Observation&#xa;NO Authorization / claim / Outcome / DomainResult&#xa;terminal stable key cannot re-execute" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12" vertex="1" parent="1"><mxGeometry x="340" y="305" width="260" height="190" as="geometry"/></mxCell>
        <mxCell id="lost" value="Lost create reply / existing / duplicate&#xa;detached Inspect has no opaqueClaim&#xa;zero Runner and zero Provider&#xa;unknown only Inspect original attempt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12" vertex="1" parent="1"><mxGeometry x="30" y="320" width="250" height="160" as="geometry"/></mxCell>
        <mxCell id="note" value="Honest boundary&#xa;Runtime shrinks, linearizes and audits TOCTOU&#xa;cross-Owner revocation window remains&#xa;no distributed atomicity / physical exactly-once / production root" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12" vertex="1" parent="1"><mxGeometry x="650" y="590" width="300" height="150" as="geometry"/></mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1" edge="1" parent="1" source="application" target="tool"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1" edge="1" parent="1" source="tool" target="gateway"><mxGeometry relative="1" as="geometry"/></mxCell>
