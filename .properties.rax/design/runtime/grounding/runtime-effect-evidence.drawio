<mxfile host="Electron" modified="2026-07-14T01:09:00.000Z" agent="Praxis" version="30.3.6"><diagram id="effect-evidence" name="Effect与Evidence"><mxGraphModel dx="1400" dy="950" grid="1" gridSize="10" page="1" pageWidth="1600" pageHeight="1100"><root><mxCell id="0"/><mxCell id="1" parent="0"/>
<mxCell id="t" value="统一Effect、Budget、Receipt与事实可信度" style="text;html=1;align=center;fontSize=24;fontStyle=1" vertex="1" parent="1"><mxGeometry x="350" y="20" width="900" height="50" as="geometry"/></mxCell>
<mxCell id="kinds" value="统一Effect分类&#xa;Context/模型费用 / Sandbox资源 / 网络&#xa;Tool/MCP / Hosted Tool / Provider Session/Batch&#xa;Prompt Cache / Credential / Artifact/Memory Commit / Safety" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14" vertex="1" parent="1"><mxGeometry x="50" y="100" width="450" height="150" as="geometry"/></mxCell>
<mxCell id="intent" value="Write-ahead EffectIntent&#xa;effect_intent_id + revision + payload digest&#xa;target / risk / Authorization / Fence&#xa;ActionRef仅为可选子类型引用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="1"><mxGeometry x="580" y="100" width="430" height="150" as="geometry"/></mxCell>
<mxCell id="budget" value="BudgetAuthorityPort&#xa;Reserve → Commit / Release&#xa;Unknown按可执行cap保留占额&#xa;无有限cap不得宣称Hard Budget&#xa;Runtime不拥有价格语义" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="1090" y="90" width="430" height="170" as="geometry"/></mxCell>
<mxCell id="dispatch" value="最终Effect边界&#xa;重验Authority + Fence&#xa;Intent和Budget均有效才Dispatch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15" vertex="1" parent="1"><mxGeometry x="580" y="330" width="430" height="110" as="geometry"/></mxCell>
<mxCell id="receipt" value="EffectReceipt / ProviderOperation ID&#xa;confirmed_applied / confirmed_not_applied" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="1"><mxGeometry x="160" y="530" width="420" height="100" as="geometry"/></mxCell>
<mxCell id="unknown" value="UnknownOutcome&#xa;不盲重试 / 不宣称失败 / 保留预算&#xa;Inspect、对账或人工协调" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14" vertex="1" parent="1"><mxGeometry x="590" y="520" width="420" height="120" as="geometry"/></mxCell>
<mxCell id="remote" value="RemoteContinuation&#xa;Session / Batch / Hosted Tool / Cache / Sidecar&#xa;独立Close、Retention和Cleanup状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14" vertex="1" parent="1"><mxGeometry x="1020" y="520" width="450" height="120" as="geometry"/></mxCell>
<mxCell id="note" value="Provenance / Observation / Attestation 是不同证据类别，互不自动升级" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1" vertex="1" parent="1"><mxGeometry x="70" y="675" width="850" height="55" as="geometry"/></mxCell>
<mxCell id="prov" value="Provenance&#xa;谁发送了什么&#xa;只证明来源" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14" vertex="1" parent="1"><mxGeometry x="70" y="760" width="250" height="100" as="geometry"/></mxCell>
<mxCell id="obs" value="Observation&#xa;组件声称看到什么&#xa;可能错误或恶意" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14" vertex="1" parent="1"><mxGeometry x="365" y="760" width="250" height="100" as="geometry"/></mxCell>
<mxCell id="att" value="Attestation&#xa;方法/范围/Digest/TTL&#xa;只在声明范围内有效" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="660" y="760" width="250" height="100" as="geometry"/></mxCell>
<mxCell id="owner" value="唯一领域事实所有者" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13" vertex="1" parent="1"><mxGeometry x="1010" y="690" width="250" height="70" as="geometry"/></mxCell>
<mxCell id="inspect" value="独立Inspect + 可验证方法" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13" vertex="1" parent="1"><mxGeometry x="1320" y="690" width="250" height="70" as="geometry"/></mxCell>
<mxCell id="fact" value="Authoritative Fact&#xa;仅由领域Owner确认&#xa;或按合同由独立Inspect形成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1" vertex="1" parent="1"><mxGeometry x="1130" y="800" width="360" height="110" as="geometry"/></mxCell>
<mxCell id="restricted" value="Restricted Evidence（密文/引用） → Operational Projection（脱敏）&#xa;各类证据可保存但类别不变；Secret正文默认不保存；Intent权威、投影可延迟" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1"><mxGeometry x="430" y="950" width="760" height="100" as="geometry"/></mxCell>
