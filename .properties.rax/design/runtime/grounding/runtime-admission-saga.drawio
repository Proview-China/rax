<mxCell id="t" value="无循环Activation对象建立与Binding Saga" style="text;html=1;align=center;fontSize=24;fontStyle=1" vertex="1" parent="1"><mxGeometry x="300" y="20" width="1100" height="50" as="geometry"/></mxCell>
<mxCell id="plan" value="ResolvedAgentPlan&#xa;不可变摘要" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14" vertex="1" parent="1"><mxGeometry x="40" y="110" width="230" height="100" as="geometry"/></mxCell>
<mxCell id="static" value="Static Admission&#xa;纯本地 / 无外部Effect&#xa;Schema、DAG、Policy、Secret检测" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1"><mxGeometry x="320" y="100" width="300" height="120" as="geometry"/></mxCell>
<mxCell id="proposed" value="1. 纯本地预留身份&#xa;Lineage = proposed&#xa;Instance ID/epoch = proposed&#xa;无执行权、无Lease" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="1"><mxGeometry x="670" y="90" width="300" height="140" as="geometry"/></mxCell>
<mxCell id="pre" value="2. Bounded Preflight&#xa;关联proposed Instance&#xa;显式Probe预算、目标、TTL&#xa;Unknown/残留不得进入Snapshot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="1020" y="90" width="310" height="140" as="geometry"/></mxCell>
<mxCell id="snap" value="3. ActivationSnapshot = frozen&#xa;绑定proposed身份 + Sandbox Requirement Digest&#xa;不引用尚不存在的Lease ID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1" vertex="1" parent="1"><mxGeometry x="1380" y="90" width="300" height="140" as="geometry"/></mxCell>
<mxCell id="idres" value="4. IdentityExecutionLease&#xa;reserved / 排他占位&#xa;只允许本attempt激活与清理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="1400" y="340" width="280" height="130" as="geometry"/></mxCell>
<mxCell id="budgetres" value="5. Budget Reservation&#xa;按Snapshot requested cap&#xa;适用时；否则明确not_required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="1060" y="340" width="280" height="130" as="geometry"/></mxCell>
<mxCell id="sbxres" value="6. SandboxLease&#xa;reserved_quarantined&#xa;禁止Harness/网络/业务凭据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14" vertex="1" parent="1"><mxGeometry x="730" y="340" width="280" height="130" as="geometry"/></mxCell>
<mxCell id="commit" value="7. 最终重验 + ActivationCommit&#xa;Identity Lease / Lineage active&#xa;Instance provisioning + 绑定Budget/Sandbox Ref" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1" vertex="1" parent="1"><mxGeometry x="260" y="330" width="420" height="150" as="geometry"/></mxCell>
