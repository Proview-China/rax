<mxCell id="saga" value="Binding Saga（按DAG）&#xa;Intent先持久化 → Apply → Receipt/Inspect&#xa;Required全部独立验证才可Ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=15;fontStyle=1" vertex="1" parent="1"><mxGeometry x="440" y="590" width="620" height="130" as="geometry"/></mxCell>
<mxCell id="fail" value="任一步失败/未知&#xa;proposed废弃；reserved需Inspect/Fence/Release&#xa;Unknown保持Quarantine与冲突域占用&#xa;不得启动Harness" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="1160" y="570" width="470" height="170" as="geometry"/></mxCell>
