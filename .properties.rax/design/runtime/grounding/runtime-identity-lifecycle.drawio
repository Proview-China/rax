<mxfile host="Electron" modified="2026-07-14T01:08:00.000Z" agent="Praxis" version="30.3.6"><diagram id="identity-lifecycle" name="对象与三维状态"><mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" page="1" pageWidth="1700" pageHeight="1100"><root><mxCell id="0"/><mxCell id="1" parent="0"/>
<mxCell id="t" value="Runtime 对象基数、无循环激活与三维状态" style="text;html=1;align=center;fontSize=24;fontStyle=1" vertex="1" parent="1"><mxGeometry x="350" y="20" width="1000" height="50" as="geometry"/></mxCell>
<mxCell id="identity" value="AgentIdentity&#xa;Organization/Authority拥有&#xa;职责主体持久" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14" vertex="1" parent="1"><mxGeometry x="50" y="100" width="270" height="110" as="geometry"/></mxCell>
<mxCell id="plan" value="ResolvedAgentPlan&#xa;Assembler拥有&#xa;不可变摘要" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="1"><mxGeometry x="50" y="260" width="270" height="110" as="geometry"/></mxCell>
<mxCell id="lineage" value="InstanceLineage 1..N historical&#xa;Runtime拥有&#xa;每个固定一个Plan Digest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1"><mxGeometry x="400" y="100" width="300" height="110" as="geometry"/></mxCell>
<mxCell id="ilease" value="IdentityExecutionLease 0..1 reserved/active&#xa;唯一线性化事实所有者&#xa;V1只指向一个Lineage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="400" y="260" width="300" height="120" as="geometry"/></mxCell>
<mxCell id="instances" value="每个Lineage → 1..N AgentInstance&#xa;每次新ID + 更高epoch&#xa;历史/当前实例使用同一基数合同" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1" vertex="1" parent="1"><mxGeometry x="790" y="100" width="330" height="120" as="geometry"/></mxCell>
<mxCell id="sandbox" value="每个active Instance → 1 SandboxLease&#xa;proposed阶段无Lease&#xa;reserved_quarantined后才可Commit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14" vertex="1" parent="1"><mxGeometry x="790" y="270" width="330" height="120" as="geometry"/></mxCell>
<mxCell id="run" value="每个Instance → 0..1 active AgentRunRecord&#xa;Runtime拥有Run Record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1"><mxGeometry x="1210" y="100" width="340" height="110" as="geometry"/></mxCell>
<mxCell id="session" value="每个Run → 0..1 SessionState / Loop&#xa;Harness拥有；仅当前Run" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="1"><mxGeometry x="1210" y="270" width="340" height="110" as="geometry"/></mxCell>
<mxCell id="activation" value="唯一激活顺序&#xa;Lineage proposed → Instance proposed → Bounded Preflight → Snapshot frozen → IdentityLease reserved&#xa;→ Budget Reservation（适用）→ SandboxLease reserved_quarantined → ActivationCommit → active SandboxLease&#xa;任一步失败：abandon/abort 或 Inspect + Fence + Release；Unknown保持Quarantine/占额" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1" vertex="1" parent="1"><mxGeometry x="180" y="470" width="1340" height="130" as="geometry"/></mxCell>
<mxCell id="vector" value="每个AgentInstance独立持有一个三维状态向量" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1" vertex="1" parent="1"><mxGeometry x="650" y="625" width="400" height="45" as="geometry"/></mxCell>
<mxCell id="life" value="LifecyclePhase&#xa;pending → ... → ready → running → stopping → terminal&#xa;terminal不可回退" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1"><mxGeometry x="70" y="690" width="460" height="120" as="geometry"/></mxCell>
<mxCell id="certainty" value="ExecutionCertainty&#xa;confirmed / unknown / lost / fenced&#xa;fenced提交态只允许stopping/terminal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="620" y="690" width="460" height="120" as="geometry"/></mxCell>
<mxCell id="cleanup" value="CleanupStatus&#xa;not_required / pending / complete / failed / indeterminate&#xa;complete只允许terminal且仅指本地清理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14" vertex="1" parent="1"><mxGeometry x="1170" y="690" width="460" height="120" as="geometry"/></mxCell>
<mxCell id="out" value="结果不可折叠：ExecutionOutcome ≠ EffectSettlement ≠ ReviewVerdict ≠ Artifact/Memory Commit ≠ Task/GoalOutcome" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1" vertex="1" parent="1"><mxGeometry x="250" y="900" width="1200" height="80" as="geometry"/></mxCell>
