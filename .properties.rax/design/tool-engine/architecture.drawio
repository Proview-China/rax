        <mxCell id="modelreader" value="Model Owner public readonly Reader&#xa;ToolCallCandidateObservationProjectionV1&#xa;Ref全字段 + ObservationDigest + Calls=1&#xa;失败时零Tool Watermark" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="1"><mxGeometry x="10" y="290" width="220" height="120" as="geometry"/></mxCell>
        <mxCell id="singlecall" value="Tool Owner start-or-inspect&#xa;Model Reader → Watermark → Candidate / Reservation&#xa;boundary绑定同Attempt execute Enforcement + Handoff&#xa;CAS成功即可能已调用；崩溃inspect-only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12" vertex="1" parent="1"><mxGeometry x="250" y="285" width="390" height="110" as="geometry"/></mxCell>
