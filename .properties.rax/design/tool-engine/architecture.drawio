        <mxCell id="relay" value="Runtime-neutral Boundary Reader&#xa;InspectCurrentOperationProviderBoundaryV1(ctx, exactRef)&#xa;Projection无SourceKind/Owner/Current&#xa;Runtime再交叉验证Operation/Attempt/execute refs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1"><mxGeometry x="650" y="420" width="260" height="120" as="geometry"/></mxCell>
