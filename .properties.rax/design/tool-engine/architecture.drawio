        <mxCell id="runtime" value="Runtime Owner&#xa;Intent → Admission → Permit → Begin&#xa;Enforcement 4.1 prepare / execute&#xa;Settlement V4 + readonly Association Inspect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14" vertex="1" parent="1"><mxGeometry x="700" y="120" width="300" height="150" as="geometry"/></mxCell>
