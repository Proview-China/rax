        <mxCell id="harness" value="Harness Owner + Assembly Adapter&#xa;PendingActionV2/waiting_action CAS&#xa;只投影Application DTO&#xa;不import Tool实现" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1"><mxGeometry x="30" y="140" width="270" height="110" as="geometry"/></mxCell>
